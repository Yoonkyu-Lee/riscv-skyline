# Default: text files with LF line endings
* text=auto eol=lf

*.c   text eol=lf
*.h   text eol=lf
*.s   text eol=lf
*.S   text eol=lf
*.ld  text eol=lf
*.py  text eol=lf
*.sh  text eol=lf
*.md  text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
Makefile text eol=lf

# Treat raw images and ELF binaries as binary
*.png binary
*.gif binary
*.jpg binary
*.elf binary
*.o   binary
*.raw binary
*.img binary
*.ppm binary
